# --- Server ---
PORT=3000

# --- WhatsApp ---
# "whatsapp-web" = live monitoring via WhatsApp Web (unofficial, see README risk note)
# "manual"       = no automation; paste/forward invite text in the dashboard
WHATSAPP_MODE=whatsapp-web

# Comma-separated chat/group names to monitor (case-insensitive, matches contact or group title).
# Leave blank to be prompted, or set to monitor only these. Example:
# WHATSAPP_WATCH=Family,College Friends,Priya
WHATSAPP_WATCH=

# Optional: use an existing Chrome/Chromium instead of the one Puppeteer downloads.
# Set this if you installed with PUPPETEER_SKIP_DOWNLOAD=1. Typical macOS path:
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
PUPPETEER_EXECUTABLE_PATH=

# --- Google Calendar ---
# Path to the OAuth client credentials JSON downloaded from Google Cloud Console.
GOOGLE_CREDENTIALS_PATH=./credentials.json
# Where the user's OAuth token is cached after first consent.
GOOGLE_TOKEN_PATH=./tokens/google-token.json
# Target calendar. "primary" is your default calendar.
GOOGLE_CALENDAR_ID=primary
# IANA timezone used when a parsed time has no explicit zone.
DEFAULT_TIMEZONE=Asia/Kolkata

# --- Location resolution ---
# "manual" = always ask you to confirm/paste an address or Maps link for vague locations.
# "places" = use Google Places API to resolve loose names (requires GOOGLE_PLACES_API_KEY).
LOCATION_MODE=manual
GOOGLE_PLACES_API_KEY=
# Optional city/region bias appended to vague location lookups (used by "places" mode).
LOCATION_DEFAULT_REGION=

# ── Profile template ───────────────────────────────────────────────────────
# Copy this to profiles/<name>.env (or use ./new-profile.sh <name>) and edit.
# Each family member gets ONE of these. Everything below is per-person.
#
# Launch this profile with:   ./run.sh <name>
# (Behind the scenes: DOTENV_CONFIG_PATH=profiles/<name>.env node src/index.js)

# Who this profile is for (just a label).
PROFILE_NAME=Someone

# Each person on the SAME machine needs a UNIQUE port. On their own machine, any port is fine.
PORT=3001

# --- WhatsApp ---
WHATSAPP_MODE=whatsapp-web
# UNIQUE per person — keeps their WhatsApp login separate. Letters/numbers/_-, no spaces.
WHATSAPP_SESSION_ID=someone
# Groups/chats this person cares about (comma-separated, case-insensitive substring match).
WHATSAPP_WATCH=Family
# Use the installed Chrome (so no 150 MB download). macOS path shown:
PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# --- Google Calendar ---
# Shared OAuth client is fine; only the TOKEN must be unique per person.
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./tokens/someone.json
GOOGLE_CALENDAR_ID=primary
# Their timezone (IANA). Examples: Asia/Kolkata, America/New_York, Europe/London
DEFAULT_TIMEZONE=Asia/Kolkata

# --- Automation (hands-off) ---
AUTO_CREATE=true
AUTO_CREATE_REQUIRE_TIME=false
LOCATION_MODE=auto
DEFAULT_LOCATION=

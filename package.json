{
  "name": "whatsapp-invite-to-calendar",
  "version": "0.1.0",
  "description": "Pulls event invites from WhatsApp Web and turns them into Google Calendar events, with a confirm-before-create review dashboard.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/index.js",
    "setup": "bash install.sh",
    "auth": "node src/google/auth.js",
    "test:parse": "node scripts/test-parse.js"
  },
  "dependencies": {
    "chrono-node": "^2.7.7",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^140.0.1",
    "multer": "^1.4.5-lts.1",
    "open": "^10.1.0",
    "pdf-parse": "^1.1.1",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.26.0"
  },
  "optionalDependencies": {
    "puppeteer": "^22.15.0"
  }
}
